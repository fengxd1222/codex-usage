#!/bin/sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)
PLUGIN_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd -P)
REPORTER="$PLUGIN_ROOT/scripts/codex_usage_reporter.py"

validate_python() {
    "$1" -c '
import sys

if sys.version_info < (3, 10):
    print(f"Python {sys.version.split()[0]} is unsupported; need Python 3.10+.")
    raise SystemExit(42)
try:
    import sqlite3  # noqa: F401
except Exception as exc:
    print(f"Python sqlite3 module is unavailable: {exc}")
    raise SystemExit(43)
' 2>&1
}

try_candidate() {
    candidate=$1
    label=$2
    shift 2
    if [ -z "$candidate" ]; then
        return 1
    fi
    if ! command -v "$candidate" >/dev/null 2>&1; then
        printf '%s\n' "codex-token-usage: $label runtime not found: $candidate" >&2
        return 1
    fi
    validation_output=$(validate_python "$candidate") || {
        printf '%s\n' "codex-token-usage: $label runtime is not usable: $candidate" >&2
        if [ -n "$validation_output" ]; then
            printf '%s\n' "$validation_output" >&2
        fi
        return 1
    }
    exec "$candidate" "$REPORTER" "$@"
}

if [ "${PYTHON:-}" ]; then
    try_candidate "$PYTHON" '$PYTHON' "$@" || true
fi

try_candidate python3 python3 "$@" || true
try_candidate python python "$@" || true

cat >&2 <<'EOF'
codex-token-usage: no usable Python runtime found.
Install Python 3.10+ with sqlite3 support, or set PYTHON=/path/to/python3.
Tried: $PYTHON, python3, python.
EOF
exit 127
